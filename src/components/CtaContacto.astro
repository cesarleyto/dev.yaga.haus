---
/* src/components/CtaContacto.astro */
---

<section class="cta-module">
  <div class="cta-image-half">
    <img src="/assets/images/code.jpg" alt="César Leyto - Developer" class="cta-img" />
  </div>

  <div class="cta-content-half fondo-acento">
    <h2 class="cta-title">Construye lo que aún no existe.</h2>
    
    <p class="cta-desc">
      Deja de depender de plataformas limitadas o personas que no les interesa tu visión a futuro. Construyamos una infraestructura propia, rápida y diseñada para convertir cada clic en un cliente real. 
    </p>
    
    <div class="cta-buttons">
      <a href="/contacto" class="btn-outline">
        <span>¡HABLEMOS DE TU PROYECTO!</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-module {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 50% - 50% */
    border-radius: var(--radius-card, 24px);
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(0,0,0,0.06);
    width: 100%;
    max-width: 1200px;
    margin: 4rem auto;
    min-height: 60vh;
  }

  /* --- MITAD DE LA IMAGEN --- */
  .cta-image-half {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  
  .cta-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  
  /* Efecto Zoom in en la foto al hacer hover en TODO el módulo */
  .cta-module:hover .cta-img {
    transform: scale(1.05);
  }

  /* --- MITAD DEL CONTENIDO --- */
  .cta-content-half {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 4.5rem;
  }
  
  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
    line-height: 1.1;
    text-wrap: balance;
  }
  
  .cta-desc {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }
  
  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* RESPONSIVE: En móviles se apila */
  @media (max-width: 900px) {
    .cta-module {
      grid-template-columns: 1fr;
      min-height: auto;
      margin: 2rem auto;
    }
    .cta-image-half {
      height: 350px; /* Altura fija en móvil para la foto */
    }
    .cta-content-half {
      padding: 3.5rem 2rem;
      text-align: center;
      align-items: center;
    }
    .cta-buttons {
      justify-content: center;
    }
  }
</style>